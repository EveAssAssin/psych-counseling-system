# ============================================
# 心理輔導系統 - 環境變數設定
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://vqyvvhaktzqakqswhktx.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# External APIs (員工資料來源)
EMPLOYEE_SYNC_API_URL=https://api.example.com/employees
EMPLOYEE_SYNC_API_KEY=your_employee_api_key

# 工單系統 API (官方頻道對話)
TICKET_SYSTEM_API_URL=https://ticket.ruki-ai.com/api/v1
TICKET_SYSTEM_API_KEY=your_ticket_api_key

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Scheduler
ENABLE_SCHEDULER=true
MONTHLY_SYNC_CRON=0 4 5 * *
DAILY_SYNC_CRON=0 5 * * *

# Logging
LOG_LEVEL=debug
