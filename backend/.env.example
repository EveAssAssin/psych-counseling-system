# ============================================
# 心理輔導系統 - 環境變數設定範本
# 複製此檔案為 .env 並填入實際值
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# JWT
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Scheduler
ENABLE_SCHEDULER=true

# Frontend URL
FRONTEND_URL=https://psych.ruki-ai.com

# Review System API（評價系統）
REVIEW_SYSTEM_API_URL=https://your-review-system.com
REVIEW_SYSTEM_API_KEY=your_review_system_api_key
